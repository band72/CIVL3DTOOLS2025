<Window x:Class="RCS.C3D2025.Tools.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RCS 2025 Tools - Help Guide" Height="680" Width="480"
        WindowStartupLocation="CenterScreen" Background="#F8FAFC">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="RCS Command Reference" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
        <TextBlock Grid.Row="1" Text="Technical manual and overview of the RCS Ribbon Tools." Foreground="#64748B" Margin="0,4,0,16"/>
        
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <ItemsControl x:Name="CmdList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="6" Margin="0,0,0,10" Padding="14">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.05"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Background="#1E293B" CornerRadius="4" Width="40" Height="40" Margin="0,0,14,0" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Number}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                                </Border>
                                
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15" Foreground="#0F172A"/>
                                    <TextBlock Text="{Binding Command}" FontFamily="Consolas" FontSize="12" Foreground="#3B82F6" Margin="0,3,0,6"/>
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="#475569" FontSize="13" LineHeight="18"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
