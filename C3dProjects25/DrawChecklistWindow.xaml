<Window x:Class="C3dProjects25.DrawChecklistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CAD Drawing Checklist" Height="650" Width="750"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Text="DWG Name:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,5"/>
            <TextBox Name="txtJobNo" Grid.Row="0" Grid.Column="1" Margin="0,0,10,5"/>
            
            <TextBlock Text="Date:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,5,5"/>
            <TextBox Name="txtDate" Grid.Row="0" Grid.Column="3" Margin="0,0,0,5" IsEnabled="False"/>
            
            <TextBlock Text="Survey Type:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,5"/>
            <ComboBox Name="cmbSurveyType" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,0,0,5" SelectionChanged="CmbSurveyType_SelectionChanged">
                <ComboBoxItem>All</ComboBoxItem>
                <ComboBoxItem>Boundary</ComboBoxItem>
                <ComboBoxItem>Topographic</ComboBoxItem>
                <ComboBoxItem>Trees</ComboBoxItem>
                <ComboBoxItem>Construction Layout Survey</ComboBoxItem>
                <ComboBoxItem>As Built / Record Survey</ComboBoxItem>
                <ComboBoxItem>Site Plan</ComboBoxItem>
                <ComboBoxItem>Drainage Plan</ComboBoxItem>
            </ComboBox>
            
            <CheckBox Name="chkPriorSurvey" Content="Prior Survey?" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,5" VerticalAlignment="Center"/>
            <CheckBox Name="chk3rdParty" Content="3rd Party Reviewed?" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,0,0,5" VerticalAlignment="Center"/>
            
            <TextBlock Text="Specific items that may need attention:" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,5,0,0" FontWeight="Bold"/>
            <TextBox Name="txtAttention" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" Height="40" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10" VerticalScrollBarVisibility="Auto"/>
        </Grid>
        
        <!-- Editable Checklist DataGrid -->
        <DataGrid Name="dgChecklist" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="True" CanUserDeleteRows="True">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Approved" Binding="{Binding IsApproved, UpdateSourceTrigger=PropertyChanged}" Width="70" CanUserSort="False"/>
                <DataGridTextColumn Header="Item Description" Binding="{Binding Description}" Width="*" CanUserSort="False"/>
            </DataGrid.Columns>
        </DataGrid>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Name="btnInsert" Content="Insert Table in Drawing" Width="150" Height="30" Margin="0,0,10,0" Click="BtnInsert_Click"/>
            <Button Name="btnCancel" Content="Cancel" Width="80" Height="30" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
